<?xml version="1.0" encoding="UTF-8"?>
<Context>

  <Resource name="jdbc/petify"
            auth="Container"
            type="javax.sql.DataSource"
            driverClassName="com.mysql.cj.jdbc.Driver"
            url="jdbc:mysql://localhost:3306/petify?useSSL=false&amp;allowPublicKeyRetrieval=true"
            username="root"
            password="n0m3l0"
            maxTotal="20"
            maxIdle="10"
            maxWaitMillis="-1"/>

  <Resources>
    <PostResources className="org.apache.catalina.webresources.DirResourceSet"
                   webAppMount="/img/productos"
                   base="C:/petify_uploads/productos"
                   internalPath="/"/>
  </Resources>

  <Realm className="org.apache.catalina.realm.DataSourceRealm"
         dataSourceName="jdbc/petify"
         userTable="usuarios"
         userNameCol="correo"
         userCredCol="contrasena"
         userRoleTable="roles"
         roleNameCol="rol"
         localDataSource="true">
    <CredentialHandler 
        className="org.apache.catalina.realm.MessageDigestCredentialHandler"
        algorithm="SHA-256"
        iterations="1"
        saltLength="0"/>
  </Realm>

</Context>